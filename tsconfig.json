{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "types": ["vite/client", "node"]
  },
  "include": [
    "src/**/*.ts",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
